# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Path to the credentials.json downloaded from GCP Console
GOOGLE_CLIENT_SECRETS_FILE=./credentials.json

# OR supply the raw JSON string contents directly (useful for Railway deployment)
GOOGLE_CLIENT_SECRETS_JSON=
GOOGLE_TOKEN_JSON=

# ─── App Store ────────────────────────────────────────────────────────────────
GROWW_PACKAGE_NAME=com.nextbillion.groww

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Storage ──────────────────────────────────────────────────────────────────
# Base directory for all flat-file storage (reviews/, pulses/, logs.jsonl)
DATA_DIR=./data
